# moriqiquanHtml 环境变量模板
# 复制为 .env 后填写实际值

# 数据库 - 阿里云 RDS（与 moriqiquan 共享）
# 若报 no encryption → 加 ?sslmode=require ；若报 server does not support SSL → 加 ?sslmode=disable
DATABASE_URL=postgresql://user:password@host:5432/barkme

# Clerk 认证（与 moriqiquan 共用 Clerk 项目）
# CLERK_PEM_PUBLIC_KEY=

# 禁用 Clerk：前后端同时设为 true 时，不登录即可访问全部报告与完整页面（最高权限）
NEXT_PUBLIC_SKIP_CLERK=true
SKIP_CLERK=true
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx



CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev

# 最全权限：将你的 Clerk User ID 填在这里（多个用逗号分隔），可看全部历史报告与完整页面
# 在 Clerk Dashboard → Users → 点进用户 → 复制 User ID（形如 user_xxx）
# ADMIN_CLERK_IDS=user_2abc123def456

# 可选：前端地址（CORS）
# 用 Network 地址访问时需包含该地址，或保持 ENV 非 production 以自动允许内网
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app