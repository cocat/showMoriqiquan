# moriqiquanHtml 环境变量模板
# 复制为 .env 后填写实际值

# 数据库 - 阿里云 RDS（与 moriqiquan 共享）
# 若报 no encryption → 加 ?sslmode=require ；若报 server does not support SSL → 加 ?sslmode=disable
DATABASE_URL=postgresql://user:password@host:5432/barkme

# 权限：SKIP_CLERK=true 仅跳过 Clerk 依赖，手机号/app token 仍按真实用户鉴权
SKIP_CLERK=false
# 仅本地调试需要“未登录也视为管理员”时才打开，线上必须保持 false
ALLOW_FAKE_ADMIN=false
CLERK_PEM_PUBLIC_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=

# 国内 Auth（支持 OIDC/JWT 的平台，如 Authing 等）
# 若使用 JWKS，优先配置 CN_AUTH_JWKS_URL；也可回退 CN_AUTH_PEM_PUBLIC_KEY
CN_AUTH_ISSUER=
CN_AUTH_JWKS_URL=
CN_AUTH_PEM_PUBLIC_KEY=
CN_AUTH_AUDIENCE=

# 可选：统一业务 token（/api/auth/exchange 会返回 app_token）
APP_AUTH_SECRET=
APP_AUTH_ISSUER=mentat-vision-api
APP_AUTH_AUDIENCE=mentat-vision-client
APP_AUTH_EXPIRES_SECONDS=86400

# 手机验证码登录（仅手机号登录场景会用到）
PHONE_OTP_TTL_SECONDS=300
PHONE_OTP_SEND_COOLDOWN_SECONDS=60
# 调试模式：后端会在 /api/auth/phone/send 响应中返回 debug_otp，便于本地联调
# 生产需换成真实短信发送，并把 PHONE_OTP_DEBUG=false 后在后端实现短信服务
PHONE_OTP_DEBUG=true
PHONE_OTP_HASH_SALT=change_me_to_a_random_salt

# 阿里云短信（当 PHONE_OTP_DEBUG=false 时启用）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_REGION_ID=cn-hangzhou

# 短信模板参数里“验证码变量名”。例如模板里用的是 {{code}}，则填 code。
PHONE_OTP_TEMPLATE_PARAM_KEY=code

# 前端 API 地址
NEXT_PUBLIC_API_URL=http://localhost:8000

# 可选：前端地址（CORS）
# 用 Network 地址访问时需包含该地址，或保持 ENV 非 production 以自动允许内网
CORS_ORIGINS=http://localhost:3000,https://mentat.hk,https://www.mentat.hk

# 可选：短渠道码映射（JSON）。示例：{"xhs":"xiaohongshu","wx":"wechat","dy":"douyin"}
# ATTR_SOURCE_ALIASES={"xhs":"xiaohongshu","wx":"wechat"}
