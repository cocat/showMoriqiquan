# 后端 API 地址。用浏览器打开 http://localhost:3000 时保持下面即可；用局域网 IP 打开时改为 http://你的电脑IP:8000，且后端需加 --host 0.0.0.0
NEXT_PUBLIC_API_URL=http://localhost:8000

# 禁用 Clerk 时设为 true（不校验登录，所有人可访问，后端需同步设 SKIP_CLERK=true）
# NEXT_PUBLIC_SKIP_CLERK=true

# Clerk 认证（启用 Clerk 时必填）
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# 境内 Auth 登录页地址（可选）。配置后前端显示“境内登录”按钮。
# 登录成功后需回跳到 /cn-auth/callback?token=...
# NEXT_PUBLIC_CN_AUTH_LOGIN_URL=https://your-cn-auth.example.com/login
